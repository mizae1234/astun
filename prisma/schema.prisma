generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// ENUMS
// ============================================================

enum Role {
  SUPER_ADMIN
  OWNER
  COMPANY_ADMIN
  BRANCH_ADMIN
  STAFF
}

enum OrderStatus {
  RECEIVED
  PREPARING
  READY
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum TransferStatus {
  PENDING
  APPROVED
  COMPLETED
  REJECTED
}

enum IntercompanyStatus {
  DRAFT
  PENDING
  APPROVED
  COMPLETED
  REJECTED
}

enum GoodsReceivingStatus {
  DRAFT
  PENDING
  INSPECTING
  COMPLETED
  PARTIAL
  REJECTED
}

enum RouteStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
}

enum StopStatus {
  PENDING
  ARRIVED
  DELIVERED
  FAILED
}

enum VehicleStatus {
  AVAILABLE
  IN_USE
  MAINTENANCE
}

// ============================================================
// ORGANIZATION: Company → Branch → Warehouse
// ============================================================

model Company {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  address     String?
  phone       String?
  email       String?
  taxId       String?
  logo        String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Invoice / Tax info
  invoicePrefix   String?  // e.g. "INV-"
  taxBranchCode   String?  // e.g. "00000" (สำนักงานใหญ่) or "00001"
  taxBranchName   String?  // e.g. "สำนักงานใหญ่"
  invoiceAddress  String?  // ที่อยู่สำหรับออก invoice (ถ้าต่างจาก address)
  invoiceNote     String?  // หมายเหตุท้าย invoice
  website         String?
  fax             String?

  branches    Branch[]
  users       User[]
  products    Product[]
  categories  Category[]
  orders      Order[]
  stocks      Stock[]
  deliveryTrips DeliveryTrip[]
  bankAccounts BankAccount[]
  productSets  ProductSet[]
  customers    Customer[]

  // Stock Transfer (same company only)
  stockTransfers StockTransfer[]

  // Intercompany
  intercompanyFrom IntercompanyTransaction[] @relation("ICFromCompany")
  intercompanyTo   IntercompanyTransaction[] @relation("ICToCompany")

  // Goods Receiving
  goodsReceivings GoodsReceiving[]
}

model Customer {
  id          String   @id @default(cuid())
  phone       String
  name        String
  email       String?
  address     String?
  taxId       String?
  companyId   String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  orders      Order[]

  @@unique([companyId, phone])
  @@index([companyId])
  @@index([phone])
}

model BankAccount {
  id          String   @id @default(cuid())
  companyId   String
  bankName    String   // ชื่อธนาคาร e.g. "กสิกรไทย"
  bankCode    String?  // รหัสธนาคาร e.g. "KBANK"
  accountName String   // ชื่อบัญชี
  accountNumber String // เลขที่บัญชี
  branchName  String?  // สาขาธนาคาร
  accountType String?  // ออมทรัพย์ / กระแสรายวัน
  isDefault   Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

model Branch {
  id          String   @id @default(cuid())
  name        String
  code        String
  address     String?
  phone       String?
  companyId   String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company     Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  warehouses  Warehouse[]
  users       User[]
  orders      Order[]
  vehicles    Vehicle[]
  deliveryTrips DeliveryTrip[]

  @@unique([companyId, code])
  @@index([companyId])
}

model Warehouse {
  id          String   @id @default(cuid())
  name        String
  code        String
  address     String?
  branchId    String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  branch      Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  stocks      Stock[]
  orders      Order[]

  transfersFrom StockTransfer[] @relation("FromWarehouse")
  transfersTo   StockTransfer[] @relation("ToWarehouse")
  goodsReceivings GoodsReceiving[]

  @@unique([branchId, code])
  @@index([branchId])
}

// ============================================================
// USER & AUTH
// ============================================================

model User {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  password      String
  role          Role     @default(STAFF)
  companyId     String?
  branchId      String?
  phone         String?
  avatar        String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  company       Company?  @relation(fields: [companyId], references: [id])
  branch        Branch?   @relation(fields: [branchId], references: [id])

  requestedTransfers StockTransfer[]    @relation("RequestedBy")
  approvedTransfers  StockTransfer[]    @relation("ApprovedBy")
  transferLogs       StockTransferLog[] @relation("PerformedBy")
  deliveryTrips      DeliveryTrip[]     @relation("Driver")

  intercompanyCreated  IntercompanyTransaction[] @relation("ICCreatedBy")
  intercompanyApproved IntercompanyTransaction[] @relation("ICApprovedBy")
  goodsReceivings      GoodsReceiving[]          @relation("GRReceivedBy")

  @@index([companyId])
  @@index([branchId])
  @@index([role])
}

// ============================================================
// PRODUCT SYSTEM
// ============================================================

model Category {
  id          String   @id @default(cuid())
  name        String
  slug        String
  description String?
  parentId    String?
  companyId   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryTree")
  company     Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  products    Product[]

  @@unique([companyId, slug])
  @@index([companyId])
  @@index([parentId])
}

model Product {
  id          String   @id @default(cuid())
  name        String
  slug        String
  description String?
  image       String?
  categoryId  String?
  companyId   String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  category    Category?        @relation(fields: [categoryId], references: [id])
  company     Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  variants    ProductVariant[]

  @@unique([companyId, slug])
  @@index([companyId])
  @@index([categoryId])
}

model ProductVariant {
  id          String   @id @default(cuid())
  sku         String
  barcode     String?  // EAN-13, UPC, or custom barcode
  name        String
  size        String?
  color       String?
  material    String?
  price       Float    @default(0)
  cost        Float    @default(0)
  weight      Float?
  productId   String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  product     Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  stocks      Stock[]
  orderItems  OrderItem[]
  transferItems StockTransferItem[]
  intercompanyItems IntercompanyTransactionItem[]
  goodsReceivingItems GoodsReceivingItem[]
  setItems    ProductSetItem[]
  unitConversions UnitConversion[]

  @@unique([sku])
  @@index([productId])
}

model ProductSet {
  id          String   @id @default(cuid())
  name        String
  sku         String   @unique
  barcode     String?
  description String?
  image       String?
  price       Float              // ราคาเซ็ต
  companyId   String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company     Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  items       ProductSetItem[]

  @@index([companyId])
}

model ProductSetItem {
  id               String   @id @default(cuid())
  setId            String
  productVariantId String
  quantity         Int

  set              ProductSet     @relation(fields: [setId], references: [id], onDelete: Cascade)
  productVariant   ProductVariant @relation(fields: [productVariantId], references: [id])

  @@index([setId])
}

model UnitConversion {
  id               String   @id @default(cuid())
  productVariantId String
  unitName         String         // "โหล", "แพค 6", "กล่อง 24"
  qtyPerUnit       Int            // 12, 6, 24
  pricePerUnit     Float          // ราคาต่อหน่วยใหญ่
  barcode          String?        // barcode เฉพาะหน่วยนี้
  isActive         Boolean  @default(true)

  productVariant   ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Cascade)

  @@unique([productVariantId, unitName])
}

// ============================================================
// INVENTORY & STOCK
// ============================================================

model Stock {
  id               String   @id @default(cuid())
  quantity         Int      @default(0)
  minQuantity      Int      @default(0)
  productVariantId String
  warehouseId      String
  companyId        String
  updatedAt        DateTime @updatedAt

  productVariant   ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Cascade)
  warehouse        Warehouse      @relation(fields: [warehouseId], references: [id], onDelete: Cascade)
  company          Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([productVariantId, warehouseId])
  @@index([companyId])
  @@index([warehouseId])
}

// ============================================================
// STOCK TRANSFER (SAME COMPANY ONLY)
// ============================================================

model StockTransfer {
  id              String         @id @default(cuid())
  transferNumber  String         @unique
  companyId       String                        // ต้องเป็นบริษัทเดียวกันเสมอ
  fromWarehouseId String
  toWarehouseId   String
  status          TransferStatus @default(PENDING)
  note            String?
  requestedById   String
  approvedById    String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  company         Company           @relation(fields: [companyId], references: [id])
  fromWarehouse   Warehouse         @relation("FromWarehouse", fields: [fromWarehouseId], references: [id])
  toWarehouse     Warehouse         @relation("ToWarehouse", fields: [toWarehouseId], references: [id])
  requestedBy     User              @relation("RequestedBy", fields: [requestedById], references: [id])
  approvedBy      User?             @relation("ApprovedBy", fields: [approvedById], references: [id])
  items           StockTransferItem[]
  logs            StockTransferLog[]

  @@index([companyId])
  @@index([status])
}

model StockTransferItem {
  id               String   @id @default(cuid())
  transferId       String
  productVariantId String
  quantity         Int

  transfer         StockTransfer  @relation(fields: [transferId], references: [id], onDelete: Cascade)
  productVariant   ProductVariant @relation(fields: [productVariantId], references: [id])

  @@index([transferId])
}

model StockTransferLog {
  id          String   @id @default(cuid())
  transferId  String
  action      String   // CREATED, APPROVED, COMPLETED, REJECTED
  performedById String
  note        String?
  createdAt   DateTime @default(now())

  transfer    StockTransfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  performedBy User          @relation("PerformedBy", fields: [performedById], references: [id])

  @@index([transferId])
}

// ============================================================
// INTERCOMPANY TRANSACTION (ข้ามบริษัท)
// ============================================================

model IntercompanyTransaction {
  id                String             @id @default(cuid())
  transactionNumber String             @unique
  fromCompanyId     String
  toCompanyId       String
  status            IntercompanyStatus @default(DRAFT)
  note              String?
  totalAmount       Float              @default(0)
  createdById       String
  approvedById      String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  fromCompany       Company @relation("ICFromCompany", fields: [fromCompanyId], references: [id])
  toCompany         Company @relation("ICToCompany", fields: [toCompanyId], references: [id])
  createdBy         User    @relation("ICCreatedBy", fields: [createdById], references: [id])
  approvedBy        User?   @relation("ICApprovedBy", fields: [approvedById], references: [id])
  items             IntercompanyTransactionItem[]

  @@index([fromCompanyId])
  @@index([toCompanyId])
  @@index([status])
}

model IntercompanyTransactionItem {
  id               String   @id @default(cuid())
  transactionId    String
  productVariantId String
  quantity         Int
  unitPrice        Float    @default(0)
  totalPrice       Float    @default(0)

  transaction      IntercompanyTransaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  productVariant   ProductVariant          @relation(fields: [productVariantId], references: [id])

  @@index([transactionId])
}

// ============================================================
// ORDER SYSTEM
// ============================================================

model Order {
  id            String      @id @default(cuid())
  orderNumber   String      @unique
  customerId    String?
  customerName  String
  customerPhone String?
  customerEmail String?
  customerAddress String?
  status        OrderStatus @default(RECEIVED)
  subtotal      Float       @default(0)  // ยอดรวมสินค้าก่อนส่วนลด
  discount      Float       @default(0)  // ส่วนลดท้ายบิล
  discountType  String?                  // "percent" | "fixed"
  addonAmount   Float       @default(0)  // ค่าบริการเพิ่ม / addon
  addonLabel    String?                  // ชื่อ addon เช่น "ค่าจัดส่ง"
  totalAmount   Float       @default(0)  // ยอดสุทธิ = subtotal - discount + addon
  note          String?
  paymentMethod String?                  // "CASH" | "TRANSFER" | "CREDIT"
  dueDate       DateTime?                // วันครบกำหนด (เฉพาะค้างชำระ)
  companyId     String
  branchId      String
  warehouseId   String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  customer      Customer?  @relation(fields: [customerId], references: [id])
  company       Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  branch        Branch     @relation(fields: [branchId], references: [id])
  warehouse     Warehouse  @relation(fields: [warehouseId], references: [id])
  items         OrderItem[]
  deliveryStops DeliveryStop[]

  @@index([companyId])
  @@index([branchId])
  @@index([status])
}

model OrderItem {
  id               String   @id @default(cuid())
  orderId          String
  productVariantId String
  quantity         Int
  unitPrice        Float
  totalPrice       Float

  order            Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productVariant   ProductVariant @relation(fields: [productVariantId], references: [id])

  @@index([orderId])
}

// ============================================================
// VEHICLE & DELIVERY
// ============================================================

model Vehicle {
  id            String        @id @default(cuid())
  licensePlate  String
  name          String?
  type          String?
  status        VehicleStatus @default(AVAILABLE)
  branchId      String
  note          String?
  isActive      Boolean       @default(true)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  branch        Branch        @relation(fields: [branchId], references: [id], onDelete: Cascade)
  trips         DeliveryTrip[]

  @@index([branchId])
}

model DeliveryTrip {
  id          String      @id @default(cuid())
  tripNumber  String      @unique
  date        DateTime
  status      RouteStatus @default(PLANNED)
  vehicleId   String?
  driverId    String?
  branchId    String
  companyId   String
  note        String?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  vehicle     Vehicle?    @relation(fields: [vehicleId], references: [id])
  driver      User?       @relation("Driver", fields: [driverId], references: [id])
  branch      Branch      @relation(fields: [branchId], references: [id])
  company     Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  stops       DeliveryStop[]

  @@index([branchId, date])
  @@index([companyId])
  @@index([vehicleId])
}

model DeliveryStop {
  id          String     @id @default(cuid())
  tripId      String
  orderId     String
  sequence    Int
  status      StopStatus @default(PENDING)
  note        String?
  arrivedAt   DateTime?
  deliveredAt DateTime?

  trip        DeliveryTrip @relation(fields: [tripId], references: [id], onDelete: Cascade)
  order       Order        @relation(fields: [orderId], references: [id])

  @@index([tripId])
}

// ============================================================
// GOODS RECEIVING (รับสินค้าเข้าคลัง)
// ============================================================

model GoodsReceiving {
  id              String               @id @default(cuid())
  grNumber        String               @unique
  supplierName    String
  supplierContact String?
  invoiceNumber   String?
  warehouseId     String
  companyId       String
  status          GoodsReceivingStatus @default(DRAFT)
  note            String?
  totalAmount     Float                @default(0)
  receivedById    String
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  completedAt     DateTime?

  warehouse       Warehouse  @relation(fields: [warehouseId], references: [id])
  company         Company    @relation(fields: [companyId], references: [id])
  receivedBy      User       @relation("GRReceivedBy", fields: [receivedById], references: [id])
  items           GoodsReceivingItem[]

  @@index([companyId])
  @@index([warehouseId])
  @@index([status])
}

model GoodsReceivingItem {
  id               String   @id @default(cuid())
  receivingId      String
  productVariantId String
  expectedQty      Int
  receivedQty      Int      @default(0)
  unitCost         Float    @default(0)
  totalCost        Float    @default(0)
  note             String?

  receiving        GoodsReceiving @relation(fields: [receivingId], references: [id], onDelete: Cascade)
  productVariant   ProductVariant @relation(fields: [productVariantId], references: [id])

  @@index([receivingId])
}
